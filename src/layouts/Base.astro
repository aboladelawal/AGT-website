---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Alpha Global Tech & Consulting — We engineer what your business runs on',
  description = 'Alpha Global Tech is an engineering and consulting firm. We build the software, systems, and automation a business runs on, engineered to hold up.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://agtconsults.com');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/images/icon.png" />
  <link rel="apple-touch-icon" href="/images/icon.png" />

  <meta property="og:title" content="Alpha Global Tech & Consulting" />
  <meta property="og:description" content="We engineer what your business runs on. Software, automation, and enterprise systems, built to hold up." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://agtconsults.com" />
  <meta property="og:image" content="https://agtconsults.com/images/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Alpha Global Tech & Consulting" />
  <meta name="twitter:description" content="We engineer what your business runs on." />
  <meta name="twitter:image" content="https://agtconsults.com/images/og-image.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- content stays visible if JS is disabled -->
  <noscript><style>.reveal{opacity:1 !important;transform:none !important;}</style></noscript>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <slot />

  <script>
    // ── nav scroll state ──
    const nav = document.getElementById('nav');
    const onScroll = () => nav && nav.classList.toggle('scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // ── scroll reveals ──
    const reveals = document.querySelectorAll<HTMLElement>('.reveal');
    if ('IntersectionObserver' in window && reveals.length) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      reveals.forEach((el) => io.observe(el));
    } else {
      reveals.forEach((el) => el.classList.add('in'));
    }

    // ── mobile nav ──
    const burger = document.getElementById('burger');
    const menu = document.getElementById('mobile-menu');
    const setMenu = (open: boolean) => {
      if (!menu || !burger) return;
      menu.classList.toggle('open', open);
      burger.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    };
    burger?.addEventListener('click', () => setMenu(!menu?.classList.contains('open')));
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setMenu(false); });

    // ── contact form: submit feedback ──
    const form = document.getElementById('ctaForm') as HTMLFormElement | null;
    form?.addEventListener('submit', () => {
      const b = document.getElementById('cf-btn') as HTMLButtonElement | null;
      if (b) { b.disabled = true; b.innerHTML = 'Sending&#8230;'; }
    });
  </script>
</body>
</html>
