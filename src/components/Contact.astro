---
import ArrowRight from './icons/ArrowRight.astro';
import Mail from './icons/Mail.astro';
import Phone from './icons/Phone.astro';
import Pin from './icons/Pin.astro';
---
<section id="contact" class="contact bleed-line sec">
  <div class="wrap">
    <div class="cta reveal">
      <div class="cta-in">
        <div class="cta-left">
          <h2 class="cta-h2">Got something that <em>needs building</em>?</h2>
          <p class="cta-lead">
            Tell us what you have in mind. We reply within two working days,
            usually sooner.
          </p>
          <div class="cta-direct">
            <a href="mailto:info@agtconsults.com"><Mail /> info@agtconsults.com</a>
            <a href="tel:+2349131356543"><Phone /> +234 913 135 6543</a>
            <span><Pin /> Lagos, Nigeria</span>
          </div>
        </div>

        <div class="cta-card">
          <form id="ctaForm" method="POST" action="/api/contact">
            <p class="hp" aria-hidden="true">
              <label>Company <input name="company" tabindex="-1" autocomplete="off" /></label>
            </p>
            <div class="cf">
              <label for="cf-name">Name</label>
              <input id="cf-name" name="name" type="text" placeholder="Your name" required />
            </div>
            <div class="cf">
              <label for="cf-email">Email</label>
              <input id="cf-email" name="email" type="email" placeholder="you@company.com" required />
            </div>
            <div class="cf">
              <label for="cf-phone">Phone <span class="opt">optional</span></label>
              <input id="cf-phone" name="phone" type="tel" placeholder="+234 ..." />
            </div>
            <div class="cf">
              <label for="cf-msg">Project</label>
              <textarea id="cf-msg" name="project" placeholder="A sentence on what you need." required></textarea>
            </div>
            <p id="cf-error" class="cf-error" role="alert" aria-live="polite" hidden></p>
            <button type="submit" class="btn btn-solid" id="cf-btn">Send enquiry<ArrowRight /></button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--bg); }
  .cta { background: var(--bone); color: #14161a; border-radius: var(--r-lg); padding: clamp(40px, 6vw, 76px) clamp(24px, 5vw, 62px); position: relative; overflow: hidden; }
  .cta::before {
    content: ''; position: absolute; right: -90px; bottom: -130px; width: 420px; height: 420px; border-radius: 50%;
    background: radial-gradient(circle, rgba(52,183,177,.22), transparent 70%);
  }
  .cta-in { position: relative; display: grid; grid-template-columns: 1.15fr 1fr; gap: clamp(36px, 5vw, 58px); align-items: center; }
  .cta-h2 { font-family: var(--serif); font-weight: 400; font-size: clamp(30px, 4.2vw, 50px); line-height: 1.03; letter-spacing: -0.03em; margin-bottom: 18px; }
  .cta-h2 em { font-style: italic; font-weight: 500; color: var(--accent-deep); }
  .cta-lead { font-size: 15.5px; color: #45484f; font-weight: 300; line-height: 1.58; max-width: 380px; margin-bottom: 28px; }
  .cta-direct { display: flex; flex-direction: column; gap: 12px; }
  .cta-direct a, .cta-direct span { font-family: var(--mono); font-size: 13px; color: #292b31; text-decoration: none; display: flex; align-items: center; gap: 10px; transition: color var(--t); }
  .cta-direct a:hover { color: var(--accent-deep); }
  .cta-direct :global(svg) { color: var(--accent-deep); flex-shrink: 0; }

  .cta-card { background: var(--bg); border-radius: var(--r); padding: 30px; }
  .cf { margin-bottom: 15px; }
  .cf label { font-family: var(--mono); font-size: 10.5px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-3); display: block; margin-bottom: 7px; }
  .opt { color: var(--text-3); opacity: .65; text-transform: none; letter-spacing: 0; }
  .cf input, .cf textarea {
    width: 100%; background: var(--surface); color: var(--text); border: 1px solid var(--line);
    border-radius: var(--r-sm); padding: 12px 14px; font-family: var(--sans); font-size: 14px;
    outline: none; transition: border-color var(--t);
  }
  .cf input:focus, .cf textarea:focus { border-color: var(--accent); }
  .cf textarea { resize: vertical; min-height: 78px; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .cf-error {
    font-size: 13px; line-height: 1.5; color: #ff9a8b;
    background: rgba(255,107,90,.08); border: 1px solid rgba(255,107,90,.28);
    border-radius: var(--r-sm); padding: 10px 13px; margin-bottom: 12px;
  }
  .cf-error[hidden] { display: none; }
  .cta-card button { width: 100%; justify-content: center; margin-top: 4px; }

  @media (max-width: 820px) { .cta-in { grid-template-columns: 1fr; } }
</style>

<script>
  // Progressive enhancement: submit same-origin via fetch so we can show inline
  // errors and avoid a full-page nav. Without JS, the form still POSTs natively
  // to /api/contact, which 303-redirects to /thank-you.html.
  const form = document.getElementById('ctaForm') as HTMLFormElement | null;
  const btn = document.getElementById('cf-btn') as HTMLButtonElement | null;
  const errBox = document.getElementById('cf-error');

  const showError = (msg: string) => {
    if (!errBox) return;
    errBox.textContent = msg;
    errBox.hidden = false;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (errBox) errBox.hidden = true;
    const original = btn?.innerHTML ?? 'Send enquiry';
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (res.ok) {
        window.location.assign('/thank-you.html');
        return;
      }
      const msg = (await res.text()).trim();
      showError(msg || 'Something went wrong. Please email info@agtconsults.com directly.');
    } catch {
      showError('Network error — please try again, or email info@agtconsults.com directly.');
    }

    if (btn) { btn.disabled = false; btn.innerHTML = original; }
  });
</script>
