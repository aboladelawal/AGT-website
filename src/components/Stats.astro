---
const stats = [
  { n: '2', label: 'Live products' },
  { n: '2023', label: 'Founded in Lagos' },
  { n: '4<em>+</em>', label: 'Products in pipeline' },
  { n: '<em>AI</em>', label: 'Powered products' },
];
---
<section class="stats bleed-line" aria-label="Company at a glance">
  <div class="wrap">
    <div class="stats-grid reveal">
      {stats.map((s, i) => (
        <div class="stat" style={`--d:${i * 0.06}s`}>
          <div class="stat-n" set:html={s.n} />
          <div class="stat-l">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats { background: var(--bg-1); }
  .stats .wrap { padding-block: clamp(48px, 7vw, 76px); }
  .stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    background: var(--line); border: 1px solid var(--line);
    border-radius: var(--r); overflow: hidden;
  }
  .stat { background: var(--bg-1); padding: clamp(28px, 3.4vw, 40px) clamp(22px, 2.6vw, 34px); }
  .stat-n {
    font-family: var(--serif); font-weight: 400; font-size: clamp(38px, 4.4vw, 52px);
    line-height: 1; letter-spacing: -0.02em; color: var(--text); margin-bottom: 12px;
  }
  .stat-n :global(em) { font-style: italic; font-weight: 500; color: var(--accent-br); }
  .stat-l {
    font-family: var(--mono); font-size: 11px; letter-spacing: .09em;
    text-transform: uppercase; color: var(--text-2);
  }
  @media (max-width: 720px) { .stats-grid { grid-template-columns: 1fr 1fr; } }
</style>
