---
const links = [
  { href: '#services', label: 'What we do' },
  { href: '#work', label: 'Our work' },
  { href: '#selected', label: 'Selected work' },
  { href: '#team', label: 'Team' },
];
const mobileExtra = [
  { href: '#flagship', label: 'Picki' },
  { href: '#havyn', label: 'Havyn' },
];
---
<nav id="nav" aria-label="Primary">
  <div class="nav-in">
    <a href="#top" class="brand" aria-label="Alpha Global Tech &amp; Consulting — home">
      <img src="/images/logo-dark.png" alt="Alpha Global Tech &amp; Consulting" width="150" height="28" />
    </a>

    <div class="nav-links">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
      <a href="#contact" class="btn btn-solid nav-cta">Start a project</a>
    </div>

    <button class="burger" id="burger" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    <div class="mm-links">
      {[...links, ...mobileExtra].map((l) => <a href={l.href}>{l.label}</a>)}
      <a href="#contact" class="btn btn-accent mm-cta">Start a project</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed; inset: 0 0 auto 0; z-index: 1000;
    border-bottom: 1px solid transparent;
    transition: background .4s var(--ease), border-color .4s, backdrop-filter .4s;
  }
  nav.scrolled {
    background: rgba(7,8,9,.72);
    backdrop-filter: blur(18px) saturate(1.4);
    border-bottom-color: var(--line-soft);
  }
  .nav-in {
    max-width: var(--maxw); margin: 0 auto; padding: 20px var(--pad);
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .brand img { height: 28px; width: auto; }
  .nav-links { display: flex; align-items: center; gap: 34px; }
  .nav-links a:not(.nav-cta) {
    text-decoration: none; color: var(--text-2); font-size: 13.5px; font-weight: 400;
    position: relative; transition: color var(--t);
  }
  .nav-links a:not(.nav-cta)::after {
    content: ''; position: absolute; left: 0; bottom: -6px; width: 0; height: 1px;
    background: var(--accent); transition: width var(--t) var(--ease);
  }
  .nav-links a:not(.nav-cta):hover { color: var(--text); }
  .nav-links a:not(.nav-cta):hover::after { width: 100%; }
  .nav-cta { padding: 10px 18px; font-size: 13px; }

  .burger {
    display: none; background: none; border: none; cursor: pointer;
    width: 38px; height: 38px; position: relative; z-index: 1200;
  }
  .burger span {
    display: block; width: 22px; height: 1.6px; background: var(--text);
    margin: 5px auto; transition: transform .34s var(--ease), opacity .2s;
  }
  .burger.is-open span:nth-child(1) { transform: translateY(6.6px) rotate(45deg); }
  .burger.is-open span:nth-child(2) { opacity: 0; }
  .burger.is-open span:nth-child(3) { transform: translateY(-6.6px) rotate(-45deg); }

  .mobile-menu {
    position: fixed; inset: 0; z-index: 1100;
    background: rgba(7,8,9,.97); backdrop-filter: blur(20px);
    display: grid; place-items: center;
    opacity: 0; visibility: hidden; transition: opacity .34s var(--ease), visibility .34s;
  }
  .mobile-menu.open { opacity: 1; visibility: visible; }
  .mm-links { display: flex; flex-direction: column; gap: 4px; text-align: center; }
  .mm-links a:not(.mm-cta) {
    text-decoration: none; color: var(--text); font-family: var(--serif);
    font-size: 30px; font-weight: 500; letter-spacing: -0.02em; padding: 10px 0;
    transition: color var(--t);
  }
  .mm-links a:not(.mm-cta):hover { color: var(--accent-br); }
  .mm-cta { margin-top: 22px; justify-content: center; }

  @media (max-width: 860px) {
    .nav-links { display: none; }
    .burger { display: block; }
  }
</style>
