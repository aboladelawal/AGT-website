---
import ArrowUpRight from './icons/ArrowUpRight.astro';
const tags = ['Multi-tenant', 'iOS + Android', 'QR verification', 'Custody delegation'];
---
<section id="havyn" class="havyn bleed-line sec">
  <div class="wrap">
    <div class="havyn-in reveal">
      <div class="havyn-visual">
        <figure class="frame frame-glow">
          <div class="frame-bar">
            <span class="fdot"></span><span class="fdot"></span><span class="fdot"></span>
            <span class="url">gethavyn.app</span>
          </div>
          <img src="/shots/gethavyn.jpg" alt="The Havyn child check-in app landing page" width="1440" height="900" loading="lazy" decoding="async" />
        </figure>
      </div>

      <div class="havyn-text">
        <p class="badge badge-live havyn-kick"><span class="pip"></span>Second live product · Havyn</p>
        <h2 class="havyn-h2">Havyn</h2>
        <p class="havyn-lead">
          A multi-tenant child check-in and check-out platform for worship
          centres, schools, daycares and camps.
        </p>
        <p class="havyn-body">
          A parent checks a child in, a verified code and QR govern release, a
          worker confirms the match. Built for accountability, live on the App
          Store and Google Play.
        </p>
        <ul class="havyn-tags">
          {tags.map((t) => <li>{t}</li>)}
        </ul>
        <a href="https://gethavyn.app" class="btn btn-accent" target="_blank" rel="noopener">
          Visit gethavyn.app<ArrowUpRight size={15} />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .havyn { background: var(--bg-1); }
  .havyn-in {
    display: grid; grid-template-columns: 1.08fr .92fr; gap: clamp(40px, 5vw, 72px);
    align-items: center;
  }
  .havyn-kick { margin-bottom: 22px; }
  .havyn-h2 { font-family: var(--serif); font-weight: 500; font-size: var(--fs-h2); letter-spacing: -0.03em; line-height: 1; margin-bottom: 18px; }
  .havyn-lead { font-size: var(--fs-lead); color: var(--text); font-weight: 300; line-height: 1.5; margin-bottom: 14px; }
  .havyn-body { font-size: 15px; color: var(--text-2); font-weight: 300; line-height: 1.62; margin-bottom: 26px; }
  .havyn-tags { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 30px; }
  .havyn-tags li {
    font-family: var(--mono); font-size: 11px; color: var(--text-3);
    border: 1px solid var(--line); padding: 5px 11px; border-radius: 6px;
  }

  .frame { border: 1px solid var(--line); border-radius: var(--r); overflow: hidden; background: var(--surface); box-shadow: var(--shadow-lg); }
  .frame-glow { box-shadow: 0 40px 90px -46px var(--accent-glow), var(--shadow-lg); }
  .frame-bar { display: flex; align-items: center; gap: 7px; padding: 12px 16px; border-bottom: 1px solid var(--line); background: var(--bg-2); }
  .fdot { width: 9px; height: 9px; border-radius: 50%; background: var(--line); }
  .url { margin-left: 14px; font-family: var(--mono); font-size: 11px; color: var(--accent); background: var(--surface); padding: 4px 12px; border-radius: 6px; border: 1px solid var(--line-soft); }
  .frame img { width: 100%; height: auto; }

  @media (max-width: 900px) {
    .havyn-in { grid-template-columns: 1fr; gap: 34px; }
    .havyn-visual { order: 2; }
  }
</style>
